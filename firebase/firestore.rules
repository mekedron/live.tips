rules_version = '2';

// live.tips Firestore rules.
//
// Default-deny: no collection is publicly readable. Fans never touch
// Firestore from the browser (the tip page is server-rendered), so the only
// client principals are the app's signed-in users — including the anonymous
// uid the relay signs in as transport for a no-account artist, which reads
// its jar's tips and nothing else.
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // Revocation watermark. revokeAllOtherDevices stamps
    // users/{uid}/private/security.sessionsValidAfterMs; an ID token minted
    // (auth_time, seconds) before that instant loses the whole users subtree
    // immediately — not after its remaining ≤1h of cryptographic validity.
    // Accounts that never revoked have no security doc and short-circuit on
    // exists(). Cost note: exists()+get() are 2 document reads per evaluated
    // operation against the 10-doc rules limit — acceptable here.
    function notRevoked(uid) {
      return !exists(/databases/$(database)/documents/users/$(uid)/private/security)
        || request.auth.token.auth_time * 1000
             >= get(/databases/$(database)/documents/users/$(uid)/private/security).data.sessionsValidAfterMs;
    }

    // A user's own subtree. Nothing inside is visible to any other uid —
    // cross-account reads are impossible by construction, URL-guessing
    // included. NO recursive owner wildcard here: overlapping matches are
    // OR'd in rules (any allow grants), so the old `{document=**}` block
    // would have handed the client the very fields the device/private
    // carve-outs below exist to protect. Each subtree the app uses is
    // matched explicitly instead; anything unlisted falls to default deny.
    match /users/{uid} {
      // Root profile doc.
      allow read, write: if isOwner(uid) && notRevoked(uid);

      // Bands and everything nested under them (secrets/v1, sessions,
      // relayTips, and the webhook-fed stripeTips delivery queue — the
      // owner reads a queued tip and deletes it, delivery IS deletion) —
      // same owner-only semantics as before. The owner could also CREATE a
      // stripeTips doc; that forges nothing but their own stage, which they
      // control anyway.
      match /bands/{document=**} {
        allow read, write: if isOwner(uid) && notRevoked(uid);
      }

      // App settings (settings/app today).
      match /settings/{document=**} {
        allow read, write: if isOwner(uid) && notRevoked(uid);
      }

      // Live-session coordination (live/current): the account's devices
      // read it to see and join the running set, and write it to start,
      // heartbeat the leader lease, edit the goal, and stop. One doc for
      // the whole account — that IS the "one session at a time" invariant.
      match /live/{document=**} {
        allow read, write: if isOwner(uid) && notRevoked(uid);
      }

      // Device registry. The app creates and maintains its own doc (name,
      // platform, model, createdAtMs, lastSeenAtMs) but `revoked` /
      // `revokedAtMs` are function-owned: a create must declare
      // revoked:false and carry no revokedAtMs; an update may change
      // neither. No client delete — delete+recreate would launder a
      // revoked:true back to false.
      match /devices/{deviceId} {
        allow read: if isOwner(uid) && notRevoked(uid);
        allow create: if isOwner(uid) && notRevoked(uid)
          && request.resource.data.revoked == false
          && !('revokedAtMs' in request.resource.data);
        allow update: if isOwner(uid) && notRevoked(uid)
          && request.resource.data.revoked == resource.data.revoked
          && request.resource.data.get('revokedAtMs', null) == resource.data.get('revokedAtMs', null);
        allow delete: if false;
      }

      // Function-written state under private/. ONLY the security doc is
      // readable (the owner may see their own revocation watermark, never
      // write it). Deliberately NOT a {document=**} read grant anymore:
      // private/stripe — the pointer to the account's Stripe connections —
      // and anything added here later fall through to the default deny,
      // because the Stripe custody path (stripeConnections/*, see below)
      // must have NO client-reachable edge, its owner included.
      match /private/security {
        allow read: if isOwner(uid) && notRevoked(uid);
        allow write: if false;
      }
    }

    // QR add-device link codes. Top-level because the redeeming device is
    // unauthenticated. Readable ONLY by the owning uid (device A's listener
    // shows the requester name + live status); the redeeming device never
    // reads the doc — it learns everything from callable returns. Every
    // write is function-mediated (the status machine lives in the callables).
    match /linkCodes/{codeId} {
      allow read: if request.auth != null
        && request.auth.uid == resource.data.uid
        && notRevoked(request.auth.uid);
      allow write: if false;
    }

    // QR sign-in requests (the mirror flow: a shared, NOT-signed-in tablet
    // shows the QR; the artist's signed-in phone scans and approves it).
    //
    // NOTHING is granted here, and that is deliberate, not an omission — do
    // not "fix" it by adding a read rule later:
    //  - the tablet that creates a request has NO uid at all, so there is no
    //    principal a read rule could even be written against; a rule loose
    //    enough to let the tablet watch its own request would let anyone
    //    enumerate every live request in the bar (and every device label in
    //    it). The tablet polls collectLoginToken instead, proving it is the
    //    creator with a collectNonce that never appears in the QR.
    //  - the approving phone has a uid, but the request is not *its* document
    //    and it needs nothing from it that describeLoginRequest does not
    //    return (the device label, the expiry) under an attempt cap and an
    //    IP quota — an unmediated read would hand a code-guesser an oracle.
    // Every transition (pending→approved→used|expired) is function-mediated.
    // Falls through to the default deny at the bottom of this file.

    // Jars: readable by the owner and linked reader devices; every write is
    // function-mediated (the callables + tip endpoint hold the invariants —
    // validation, quotas, hashed secrets — that rules cannot express).
    match /jars/{jarId} {
      allow read: if request.auth != null &&
        (resource.data.ownerUid == request.auth.uid || request.auth.uid in resource.data.readerUids);
      allow write: if false;

      // Pending tips: the artist's devices read them and delete them once
      // shown (delivery IS deletion — the relay keeps no tip history). Only
      // the tip function creates them; nobody edits one in place.
      match /pendingTips/{tipId} {
        allow read, delete: if request.auth != null &&
          (get(/databases/$(database)/documents/jars/$(jarId)).data.ownerUid == request.auth.uid
           || request.auth.uid in get(/databases/$(database)/documents/jars/$(jarId)).data.readerUids);
        allow create, update: if false;
      }

      // Secret hash and rate/dedupe state: server-only, always.
      match /private/{doc} { allow read, write: if false; }
    }

    // Quota buckets (salted IP hashes, uid day-buckets): server-only.
    match /rateLimits/{key} { allow read, write: if false; }

    // Cloud Stripe connections: the envelope-encrypted restricted key and
    // webhook signing secret (KMS-wrapped — a Firestore dump alone is
    // worthless, see functions/src/stripe-crypto.ts). Server-only, ALWAYS,
    // for every principal including the owning artist: the entire point of
    // key custody is that no device ever holds the key again, so no rule
    // here may ever grant a read. Explicit rather than falling through to
    // the default deny, so nobody "opens it up" without meeting this comment.
    match /stripeConnections/{connectionId} { allow read, write: if false; }

    // The webhook's dedupe tombstones (functions/src/stripe-webhook.ts):
    // they outlive delivered tips so a Stripe redelivery cannot re-stage a
    // collected tip. Server-only, like every other rate/dedupe record.
    match /processedEvents/{objectId} { allow read, write: if false; }

    // Everything else is closed until a later phase opens it explicitly.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
