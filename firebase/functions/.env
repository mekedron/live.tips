# Non-secret function params (secrets live in Secret Manager — see README).
# The real, public Turnstile sitekey for live.tips — deployed verbatim,
# nothing substitutes it. Safe to commit (sitekeys are served in the tip
# page HTML anyway); the paired TURNSTILE_SECRET is a Secret Manager secret.
TURNSTILE_SITE_KEY=0x4AAAAAADxbXSyz6hPQKTiZ

# Where Stripe POSTs a connected artist's events — the Hosting rewrite in
# front of stripeWebhook. Not a secret: the artist sees this URL in their own
# Stripe dashboard. The path carries a 128-bit connectionId, and the SIGNATURE
# is the auth, not the URL.
STRIPE_WEBHOOK_BASE=https://tip.live.tips/stripe/webhook

# The KMS key that wraps the data keys that seal artists' Stripe secrets.
# A resource PATH, not key material — naming it grants nothing; only the
# functions' service account may call decrypt on it. Both params carry the
# same defaults in code, but the CLI will not deploy non-interactively
# without a value, and a value you can read here beats one buried in a module.
KMS_KEY_RESOURCE=projects/livetips-app/locations/europe-west1/keyRings/livetips/cryptoKeys/stripe-secrets
